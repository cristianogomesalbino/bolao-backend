{
  "enabled": true,
  "name": "Gerar Mapa de Endpoints",
  "description": "Quando um controller é salvo, regenera docs/endpoints.md automaticamente com a tabela de endpoints e seu uso no front-end",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.controller.ts"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "node scripts/generate-endpoints.js"
  }
}
