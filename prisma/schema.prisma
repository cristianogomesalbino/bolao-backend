generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campeonato {
  id         String      @id @default(uuid())
  nome       String
  temporadas Temporada[]
}

model Temporada {
  id           String     @id @default(uuid())
  ano          Int
  campeonatoId String
  campeonato   Campeonato @relation(fields: [campeonatoId], references: [id])

  grupos Grupo[]

  dataCriacao DateTime @default(now())
}

model Grupo {
  id                        String    @id @default(uuid())
  nome                      String    @unique @db.VarChar(100)
  temporadaId               String
  adminId                   String

  privado                   Boolean
  codigoConvite             String?   @unique @db.VarChar(8)

  permitirPalpiteAutomatico Boolean   @default(false)
  maxParticipantes          Int       @default(50)

  ativo                     Boolean   @default(true)
  dataCriacao               DateTime  @default(now())

  temporada                 Temporada @relation(fields: [temporadaId], references: [id])
  admin                     Usuario   @relation(fields: [adminId], references: [id])
}

model Usuario {
  id            String   @id @default(uuid())
  nome          String   @db.VarChar(100)
  email         String   @unique @db.VarChar(150)
  senha         String   @db.VarChar(255)
  timeDoCoracao String?  @db.VarChar(100)
  dataCriacao   DateTime @default(now())

  gruposAdmin Grupo[]
}
