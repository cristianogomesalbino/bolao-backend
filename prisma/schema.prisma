generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campeonato {
  id         String      @id @default(uuid())
  nome       String
  temporadas Temporada[]
}

model Temporada {
  id           String     @id @default(uuid())
  ano          Int
  campeonatoId String
  campeonato   Campeonato @relation(fields: [campeonatoId], references: [id])

  grupos Grupo[]

  dataCriacao DateTime @default(now())
}

model Usuario {
  id     String @id @default(uuid())
  nome   String
  email  String @unique
  senha  String
  perfil Perfil @default(USER)

  gruposCriados Grupo[]        @relation("GrupoCriador")
  grupos        GrupoUsuario[]

  dataCriacao  DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model Grupo {
  id          String @id @default(uuid())
  nome        String @unique @db.VarChar(100)
  temporadaId String

  privado       Boolean
  codigoConvite String? @unique @db.VarChar(8)

  permitirPalpiteAutomatico Boolean @default(false)
  maxParticipantes          Int     @default(50)

  ativo       Boolean  @default(true)
  dataCriacao DateTime @default(now())

  createdById String
  createdBy   Usuario @relation("GrupoCriador", fields: [createdById], references: [id])

  temporada Temporada      @relation(fields: [temporadaId], references: [id])
  usuarios  GrupoUsuario[]
}

model GrupoUsuario {
  id String @id @default(uuid())

  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  usuarioId String

  grupo   Grupo  @relation(fields: [grupoId], references: [id])
  grupoId String

  role GrupoRole @default(MEMBER)

  @@unique([usuarioId, grupoId])
}

enum Perfil {
  SUPER_ADMIN
  USER
}

enum GrupoRole {
  ADMIN
  MEMBER
}
