generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Campeonato {
  id           String      @id @default(uuid())
  nome         String
  dataCriacao  DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt
  temporadas   Temporada[]
}

model Temporada {
  id                String             @id @default(uuid())
  ano               Int
  dataCriacao       DateTime           @default(now())
  atualizadoEm      DateTime           @updatedAt
  campeonatoId      String
  fases             Fase[]
  grupos            Grupo[]
  campeonato        Campeonato         @relation(fields: [campeonatoId], references: [id])
  recordesSequencia RecordeSequencia[]
}

model Usuario {
  id                     String                  @id @default(uuid())
  nome                   String
  email                  String                  @unique
  senha                  String
  dataCriacao            DateTime                @default(now())
  atualizadoEm           DateTime                @updatedAt
  perfil                 Perfil                  @default(USER)
  ativo                  Boolean                 @default(true)
  grupoFavoritoId        String?
  grupoFavorito          Grupo?                  @relation("GrupoFavorito", fields: [grupoFavoritoId], references: [id])
  gruposCriados          Grupo[]                 @relation("GrupoCriador")
  grupos                 GrupoUsuario[]
  palpites               Palpite[]
  palpitesDobrados       PalpiteDobrado[]
  recuperacoesSenha      RecuperacaoSenha[]
  refreshTokens          RefreshToken[]
  tokensDobro            TokenDobro[]
  notificacoes           Notificacao[]
  inscricoesPush         InscricaoPush[]
  preferenciaNotificacao PreferenciaNotificacao?
  stories                Story[]
  storyReacoes           StoryReacao[]
  storyVisualizacoes     StoryVisualizacao[]
}

model Grupo {
  id                        String             @id @default(uuid())
  nome                      String             @unique @db.VarChar(100)
  temporadaId               String
  criadoPor                 String
  privado                   Boolean
  codigoConvite             String?            @unique @db.VarChar(8)
  icone                     String?
  permitirPalpiteAutomatico Boolean            @default(false)
  maxParticipantes          Int                @default(50)
  ativo                     Boolean            @default(true)
  permitirPalpiteDobrado    Boolean            @default(false)
  dataCriacao               DateTime           @default(now())
  atualizadoEm              DateTime           @updatedAt
  criador                   Usuario            @relation("GrupoCriador", fields: [criadoPor], references: [id])
  temporada                 Temporada          @relation(fields: [temporadaId], references: [id])
  usuarios                  GrupoUsuario[]
  usuariosFavorito          Usuario[]          @relation("GrupoFavorito")
  palpitesDobrados          PalpiteDobrado[]
  tokensDobro               TokenDobro[]
  stories                   Story[]
  recordesSequencia         RecordeSequencia[]
  rankingSnapshots          RankingSnapshot[]
}

model GrupoUsuario {
  id           String    @id @default(uuid())
  usuarioId    String
  grupoId      String
  role         GrupoRole @default(MEMBER)
  dataCriacao  DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  grupo        Grupo     @relation(fields: [grupoId], references: [id])
  usuario      Usuario   @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, grupoId])
}

model RefreshToken {
  id          String   @id @default(uuid())
  token       String   @unique
  usuarioId   String
  expiraEm    DateTime
  dataCriacao DateTime @default(now())
  usuario     Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model RecuperacaoSenha {
  id          String   @id @default(uuid())
  token       String   @unique
  usuarioId   String
  expiraEm    DateTime
  usado       Boolean  @default(false)
  dataCriacao DateTime @default(now())
  usuario     Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
}

model Fase {
  id           String    @id @default(uuid())
  nome         String
  tipo         TipoFase
  ordem        Int
  idaVolta     Boolean   @default(false)
  temporadaId  String
  dataCriacao  DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  temporada    Temporada @relation(fields: [temporadaId], references: [id])
  jogos        Jogo[]

  @@index([temporadaId])
}

model Time {
  id           String   @id @default(uuid())
  nome         String
  sigla        String   @unique
  escudo       String?
  externoId    String?  @unique
  dataCriacao  DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  jogosCasa    Jogo[]   @relation("TimeCasa")
  jogosFora    Jogo[]   @relation("TimeFora")
}

model Jogo {
  id                  String           @id @default(uuid())
  faseId              String
  timeCasaId          String
  timeForaId          String
  dataHora            DateTime?
  rodada              Int?
  status              StatusJogo       @default(AGENDADO)
  golsCasa            Int?
  golsFora            Int?
  temProrrogacao      Boolean          @default(false)
  golsProrrogacaoCasa Int?
  golsProrrogacaoFora Int?
  temPenaltis         Boolean          @default(false)
  penaltisCasa        Int?
  penaltisFora        Int?
  vencedorId          String?
  ehJogoVolta         Boolean          @default(false)
  grupoIdaVolta       String?
  fonteResultado      FonteResultado   @default(MANUAL)
  foiAdiado           Boolean          @default(false)
  externoId           String?          @unique
  criadoPor           String
  dataCriacao         DateTime         @default(now())
  atualizadoEm        DateTime         @updatedAt
  fase                Fase             @relation(fields: [faseId], references: [id])
  timeCasa            Time             @relation("TimeCasa", fields: [timeCasaId], references: [id])
  timeFora            Time             @relation("TimeFora", fields: [timeForaId], references: [id])
  palpites            Palpite[]
  palpitesDobrados    PalpiteDobrado[]
  stories             Story[]

  @@index([faseId])
  @@index([timeCasaId])
  @@index([timeForaId])
}

model Palpite {
  id           String   @id @default(uuid())
  usuarioId    String
  jogoId       String
  golsCasa     Int
  golsFora     Int
  dataCriacao  DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  jogo         Jogo     @relation(fields: [jogoId], references: [id])
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, jogoId])
  @@index([jogoId])
  @@index([usuarioId])
}

model PalpiteDobrado {
  id          String   @id @default(uuid())
  usuarioId   String
  jogoId      String
  grupoId     String
  dataCriacao DateTime @default(now())
  grupo       Grupo    @relation(fields: [grupoId], references: [id])
  jogo        Jogo     @relation(fields: [jogoId], references: [id])
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, jogoId, grupoId])
  @@index([jogoId, grupoId])
}

model TokenDobro {
  id           String           @id @default(uuid())
  usuarioId    String
  grupoId      String
  tipo         TipoTokenDobro
  motivo       MotivoTokenDobro
  referenciaId String
  dataCriacao  DateTime         @default(now())
  grupo        Grupo            @relation(fields: [grupoId], references: [id])
  usuario      Usuario          @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId, grupoId])
}

enum Perfil {
  SUPER_ADMIN
  USER
}

enum GrupoRole {
  ADMIN
  MEMBER
}

enum TipoFase {
  PONTOS_CORRIDOS
  MATA_MATA
}

enum StatusJogo {
  AGENDADO
  ADIADO
  EM_ANDAMENTO
  FINALIZADO
  CANCELADO
}

enum FonteResultado {
  MANUAL
  API_EXTERNA
}

enum TipoTokenDobro {
  CONCESSAO
  UTILIZACAO
}

enum MotivoTokenDobro {
  PALPITES_COMPLETOS
  ACERTO_EM_CHEIO
  ULTIMO_RANKING
  PRIMEIRO_RANKING
  ATIVACAO_DOBRO
  CANCELAMENTO_DOBRO
}

model LogSincronizacao {
  id             String              @id @default(uuid())
  campeonatoSlug String
  fasesIds       String[]
  totalJogos     Int
  sincronizados  Int
  erros          Int                 @default(0)
  status         StatusSincronizacao
  mensagem       String?
  duracaoMs      Int
  dataCriacao    DateTime            @default(now())
  detalhes       Json?

  @@index([campeonatoSlug])
  @@index([dataCriacao])
  @@index([status])
}

enum StatusSincronizacao {
  SUCESSO
  PARCIAL
  ERRO
  SEM_JOGOS
}

enum TipoNotificacao {
  JOGO_PROXIMO
  RODADA_ENCERRADA
  ACERTO_EM_CHEIO
  SUBIU_POSICAO
  DESCEU_POSICAO
  PALPITES_PENDENTES
  JOGO_LIBERADO
  STORIES_GRUPO
  RECEBEU_F
}

enum StatusNotificacao {
  NAO_LIDA
  LIDA
}

model Notificacao {
  id          String            @id @default(uuid())
  tipo        TipoNotificacao
  titulo      String            @db.VarChar(100)
  mensagem    String            @db.VarChar(500)
  status      StatusNotificacao @default(NAO_LIDA)
  usuarioId   String
  jogoId      String?
  grupoId     String?
  faseId      String?
  rodada      Int?
  dataCriacao DateTime          @default(now())
  dataLeitura DateTime?

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, status, dataCriacao])
  @@index([usuarioId, dataCriacao])
  @@index([jogoId, tipo])
  @@index([faseId, rodada, tipo])
}

model InscricaoPush {
  id           String   @id @default(uuid())
  usuarioId    String
  endpoint     String   @db.VarChar(2048)
  p256dh       String   @db.VarChar(128)
  auth         String   @db.VarChar(48)
  dataCriacao  DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, endpoint])
  @@index([usuarioId])
}

model PreferenciaNotificacao {
  id                String  @id @default(uuid())
  usuarioId         String  @unique
  jogoProximo       Boolean @default(true)
  rodadaEncerrada   Boolean @default(true)
  acertoEmCheio     Boolean @default(true)
  subiuPosicao      Boolean @default(true)
  desceuPosicao     Boolean @default(true)
  palpitesPendentes Boolean @default(true)
  jogoLiberado      Boolean @default(true)
  storiesGrupo      Boolean @default(true)
  recebeuF          Boolean @default(true)

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

// --- Módulo Eventos (outbox pattern local) ---

enum StatusEvento {
  PENDENTE
  PROCESSANDO
  PROCESSADO
  FALHA_DEFINITIVA
}

model EventoPendente {
  id                String       @id @default(uuid())
  tipo              String       @db.VarChar(50)
  chaveIdempotencia String       @unique @db.VarChar(200)
  payload           Json
  status            StatusEvento @default(PENDENTE)
  tentativas        Int          @default(0)
  ultimoErro        String?      @db.VarChar(500)
  syncId            String?
  dataCriacao       DateTime     @default(now())
  processadoEm      DateTime?
  atualizadoEm      DateTime     @updatedAt

  @@index([status])
  @@index([tipo, status])
}

// ============================================
// MÓDULO STORIES
// ============================================

enum TipoStory {
  ACERTOU_EM_CHEIO
  UNICO_NA_MOSCA
  SUBIU_RANKING
  SEQUENCIA_MOSCA
  SEQUENCIA_RESULTADO
  NAO_PALPITOU
  DOBROU_E_ACERTOU
}

model Story {
  id         String    @id @default(uuid())
  grupoId    String
  usuarioId  String
  jogoId     String
  rodada     Int?
  tipo       TipoStory
  dados      Json
  titulo     String    @db.VarChar(100)
  contadorFs Int       @default(0)
  criadoEm   DateTime  @default(now())

  grupo         Grupo               @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  usuario       Usuario             @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  jogo          Jogo                @relation(fields: [jogoId], references: [id], onDelete: Cascade)
  reacoes       StoryReacao[]
  visualizacoes StoryVisualizacao[]

  @@unique([grupoId, usuarioId, jogoId, tipo])
  @@index([grupoId, criadoEm])
  @@index([grupoId, usuarioId])
  @@index([grupoId, rodada])
}

model StoryReacao {
  id          String   @id @default(uuid())
  storyId     String
  remetenteId String
  criadoEm    DateTime @default(now())

  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])
  usuarioId String?

  @@unique([remetenteId, storyId])
  @@index([storyId])
}

model StoryVisualizacao {
  id            String   @id @default(uuid())
  storyId       String
  usuarioId     String
  visualizadoEm DateTime @default(now())

  story   Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([storyId, usuarioId])
  @@index([storyId])
  @@index([usuarioId])
}

enum CategoriaRecorde {
  MOSCA
  RESULTADO
}

model RecordeSequencia {
  id           String           @id @default(uuid())
  grupoId      String
  temporadaId  String
  categoria    CategoriaRecorde
  valor        Int
  criadoEm     DateTime         @default(now())
  atualizadoEm DateTime         @updatedAt

  grupo      Grupo             @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  temporada  Temporada         @relation(fields: [temporadaId], references: [id], onDelete: Cascade)
  detentores RecordeDetentor[]

  @@unique([grupoId, temporadaId, categoria])
  @@index([grupoId, temporadaId])
}

model RecordeDetentor {
  id         String   @id @default(uuid())
  recordeId  String
  usuarioId  String
  atingidoEm DateTime @default(now())

  recorde RecordeSequencia @relation(fields: [recordeId], references: [id], onDelete: Cascade)

  @@unique([recordeId, usuarioId])
  @@index([recordeId])
}

model RankingSnapshot {
  id        String   @id @default(uuid())
  grupoId   String
  usuarioId String
  faseId    String
  rodada    Int?
  posicao   Int
  pontuacao Int
  criadoEm  DateTime @default(now())

  grupo Grupo @relation(fields: [grupoId], references: [id], onDelete: Cascade)

  @@unique([grupoId, usuarioId, faseId, rodada])
  @@index([grupoId, faseId, rodada])
}
