##### CONFIGURACAO PLAYWRIGHT ###

# Supabase Pooler (Transaction Mode)
# Dados extraídos da DATABASE_URL do projeto:
# postgresql://USER:PASS@HOST:PORT/DATABASE
DB_HOST=aws-X-XX-XXXX-X.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.SEU_PROJECT_REF
DB_PASS=SUA_SENHA_AQUI
DB_SSL=true

# URL da API — backend rodando local com network_mode: host
# Em dev local: http://localhost:3002/
# Em Docker com rede interna: http://NOME_DO_CONTAINER:PORTA/
RESOURCES_URL=http://localhost:3002/

###### FIM CONFIGURACAO PLAYWRIGHT ###
